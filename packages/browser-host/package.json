  "type": "module",
  "description": "Browser host runtime and bootstrap helpers for marketplace and single-xapp surfaces",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./backend-base": "./dist/backend-base.js",
    "./launcher-core": {
      "types": "./dist/launcher-core.d.ts",
      "default": "./dist/launcher-core.js"
    },
    "./embed-surface": {
      "types": "./dist/embed-surface.d.ts",
      "default": "./dist/embed-surface.js"
    },
    "./standard-runtime": {
      "types": "./dist/standard-runtime.d.ts",
      "default": "./dist/standard-runtime.js"
    },
    "./subject-profile": {
      "types": "./subject-profile.d.ts",
      "default": "./dist/subjectProfile.js"
    },
    "./modal-shell": {
      "types": "./modal-shell.d.ts",
      "default": "./dist/modalShell.js"
    },
    "./xms": {
      "types": "./xms.d.ts",
      "default": "./dist/xms.js"
    },
    "./xms-copy": {
      "types": "./xms-copy.d.ts",
      "default": "./dist/xmsCopy.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "modal-shell.d.ts",
    "subject-profile.d.ts",
    "xms.d.ts",
    "xms-copy.d.ts"
  ],
  "publishConfig": {
    "access": "public"
